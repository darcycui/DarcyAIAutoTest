{
  "name": "midscene",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "dependencies": {
    "@midscene/android": "^1.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@midscene/android": "latest",
    "dotenv": "^16.4.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "build-debug": "bun build ./src/index.ts --outdir ./out --target=node", 
    "build-release": "bun build ./src/index.ts --outdir ./out --target=node --minify && npx terser ./out/index.js --compress --mangle -o ./out/index.min.js" 
  
  }
}
